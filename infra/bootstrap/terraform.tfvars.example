# AWS Configuration
aws_region = "us-east-1"

# GitHub Repository
github_repo   = "yourusername/cost-sentinel"
github_branch = "main"

# S3 Bucket Names (must be globally unique; names must contain "cost-sentinel"
# to satisfy the deploy role's S3 scope, and prod names must differ from dev)
artifact_bucket_name       = "your-unique-prefix-cost-sentinel-artifacts"
tf_state_bucket_name       = "your-unique-prefix-cost-sentinel-tfstate"
alerts_bucket_name_dev     = "your-unique-prefix-cost-sentinel-app-alerts"
dashboard_bucket_name_dev  = "your-unique-prefix-cost-sentinel-dashboard-site"
alerts_bucket_name_prod    = "your-unique-prefix-cost-sentinel-prod-app-alerts"
dashboard_bucket_name_prod = "your-unique-prefix-cost-sentinel-prod-dashboard-site"

# Budget Configuration
# budget_email feeds dev's optional Terraform-managed email subscription.
# Prod's email subscription is created manually in the Console (kept out of IaC).
budget_email              = "your-email@example.com" # Optional (dev only)
monthly_budget_usd        = 10
budget_thresholds_percent = [10, 50, 80, 100]
